{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@photobooth/core": ["packages/core/src/index.ts"],
      "@photobooth/ui": ["packages/ui/src/index.ts"],
      "@photobooth/ui/*": ["packages/ui/src/*"]
    }
  }
}
