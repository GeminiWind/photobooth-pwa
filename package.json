{
  "name": "photobooth-pwa",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @photobooth/web run dev",
    "build:web": "npm --workspace @photobooth/web run build",
    "dev:desktop": "npm --workspace @photobooth/desktop run dev",
    "build:desktop": "npm --workspace @photobooth/desktop run build",
    "build:mac": "npm --workspace @photobooth/desktop run build:mac",
    "build:win": "npm --workspace @photobooth/desktop run build:win",
    "lint": "eslint .",
    "typecheck": "npm run typecheck -ws",
    "test": "npm run test -ws"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.19.11",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.26.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
