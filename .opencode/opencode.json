{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [ "npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
     "task-master-ai": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "task-master-ai"
      ],
      "enabled": true,
      "environment": {
        "TASK_MASTER_TOOLS": "core",
        "OPENAI_API_KEY": ""
      }
    }
  }
}
